# 로컬 개발용 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사하고 실제 값 입력
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Mac/Linux:             cp .env.example .env
# ===================================

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=usedtrade
MYSQL_USER=usedtrade_user
