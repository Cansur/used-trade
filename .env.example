# ===================================
# 로컬 개발용 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사하고 실제 값 입력
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Mac/Linux:             cp .env.example .env
# ===================================

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=usedtrade
MYSQL_USER=usedtrade_user
MYSQL_PASSWORD=change_me_user

# Redis
REDIS_PASSWORD=change_me_redis

# JWT
# HS256 서명에는 최소 32바이트(256비트) 이상의 비밀키가 필요.
# 운영 생성:  openssl rand -base64 48
JWT_SECRET=please_change_me_to_a_long_random_string_at_least_32_bytes_long
JWT_ACCESS_TOKEN_VALIDITY_MS=1800000        # 30분
JWT_REFRESH_TOKEN_VALIDITY_MS=1209600000    # 14일
JWT_ISSUER=used-trade
